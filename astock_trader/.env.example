# 环境变量配置

# 数据库
DATABASE_URL=sqlite:///data/trader.db

# Redis（可选）
REDIS_HOST=localhost
REDIS_PORT=6379

# API服务
API_HOST=0.0.0.0
API_PORT=8000

# Web服务
WEB_PORT=8501

# 交易配置
INITIAL_CASH=100000
COMMISSION=0.003

# QMT券商配置（待填写）
# QMT_PATH=/path/to/QMT
# QMT_ACCOUNT=your_account
# QMT_PASSWORD=your_password
# Web authentication (required)
APP_PASSWORD=replace-with-a-long-random-password
SESSION_TTL_SECONDS=28800
CORS_ORIGINS=http://127.0.0.1:8888,http://localhost:8888
